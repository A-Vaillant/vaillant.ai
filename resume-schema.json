{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resume Data Schema",
  "description": "Schema for resume.json - fill this out with your actual resume data",
  "type": "object",
  "required": ["name", "email", "summary"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Your full name",
      "example": "Aleister Vaillant"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Your email address",
      "example": "aleister@vaillant.ai"
    },
    "location": {
      "type": "string",
      "description": "Your location (city, state/country)",
      "example": "New York, NY"
    },
    "linkedin": {
      "type": "string",
      "format": "uri",
      "description": "LinkedIn profile URL",
      "example": "https://www.linkedin.com/in/alvaillant/"
    },
    "github": {
      "type": "string",
      "format": "uri",
      "description": "GitHub profile URL",
      "example": "https://github.com/A-Vaillant"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Personal website URL (optional)"
    },
    "summary": {
      "type": "string",
      "description": "Brief professional summary (1-3 sentences)",
      "example": "Software engineer and researcher with expertise in machine learning, systems programming, and full-stack development."
    },
    "education": {
      "type": "array",
      "description": "Educational background",
      "items": {
        "type": "object",
        "required": ["institution", "degree", "graduation"],
        "properties": {
          "institution": {
            "type": "string",
            "example": "New York University"
          },
          "degree": {
            "type": "string",
            "example": "BS in Computer Science"
          },
          "graduation": {
            "type": "string",
            "description": "Graduation year or expected graduation",
            "example": "2025"
          },
          "gpa": {
            "type": "number",
            "description": "GPA (optional)",
            "example": 3.8
          },
          "relevant_coursework": {
            "type": "array",
            "description": "List of relevant courses (optional)",
            "items": {
              "type": "string"
            },
            "example": ["Machine Learning", "Operating Systems", "Computer Networks"]
          }
        }
      }
    },
    "experience": {
      "type": "array",
      "description": "Work experience (optional - can be empty array)",
      "items": {
        "type": "object",
        "required": ["title", "company", "start_date", "end_date"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Software Engineering Intern"
          },
          "company": {
            "type": "string",
            "example": "Example Corp"
          },
          "location": {
            "type": "string",
            "example": "Remote"
          },
          "start_date": {
            "type": "string",
            "example": "June 2024"
          },
          "end_date": {
            "type": "string",
            "description": "Use 'Present' for current positions",
            "example": "August 2024"
          },
          "achievements": {
            "type": "array",
            "description": "List of achievements/responsibilities",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "description": "Personal or academic projects",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "example": "factorio-working-group-one"
          },
          "description": {
            "type": "string",
            "example": "Investigation into application of CNNs for automating factory creation in Factorio"
          },
          "technologies": {
            "type": "array",
            "description": "Technologies/languages used",
            "items": {
              "type": "string"
            },
            "example": ["Python", "TensorFlow", "Computer Vision"]
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "Project URL (GitHub, demo, etc.)"
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "description": "Skills organized by category",
      "properties": {
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": ["Python", "JavaScript", "C++"]
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": ["React", "Node.js", "TensorFlow"]
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": ["Git", "Docker", "Linux"]
        }
      },
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "You can add custom skill categories"
      }
    }
  }
}
